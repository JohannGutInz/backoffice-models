generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum UserRole {
  ADMIN
  USER
}

model User {
  id             String   @id @default(uuid())
  email          String   @unique
  username       String
  hashedPassword String   @map("hashed_password")
  role           UserRole @default(USER)
  createdAt      DateTime @default(now()) @map("created_at")

  agencyId String @map("agency_id")
  agency   Agency @relation(fields: [agencyId], references: [id])

  @@map("users")
}

model Agency {
  id        String   @id @default(uuid())
  name      String
  createdAt DateTime @default(now()) @map("created_at")

  users User[]

  @@map("agencies")
}

model Country {
  id      String @id @default(uuid())
  name    String
  label   String @unique
  demonym String

  models Model[]
  states State[]

  @@map("countries")
}

model State {
  id    String @id @default(uuid())
  name  String
  label String @unique

  cities Municipality[]

  countryId String  @map("country_id")
  country   Country @relation(fields: [countryId], references: [id])

  @@map("states")
}

model Municipality {
  id    String @id @default(uuid())
  name  String
  label String @unique

  stateId String @map("state_id")
  state   State  @relation(fields: [stateId], references: [id])

  models Model[]

  @@map("municipalities")
}

model Category {
  id      String  @id @default(uuid())
  name    String  @unique
  enabled Boolean @default(true)

  models Model[]

  @@map("categories")
}

enum ModelGenre {
  MALE
  FEMALE
}

enum KycStatus {
  PENDING
  APPROVED
  REJECTED
  REQUIRES_CHANGES
}

enum PackageStatus {
  DRAFT
  SENT
  CLOSED
}

enum MediaType {
  PHOTO_CASUAL
  PHOTO_BOOK
  PHOTO_EVENT
  VIDEO_LINK
}

model Kyc {
  id           String    @id @default(uuid())
  status       KycStatus @default(PENDING)
  comment      String?
  internalNote String?   @map("internal_note")
  rejectedAt   DateTime? @map("rejected_at")
  reviewedAt   DateTime? @map("reviewed_at")
  createdAt    DateTime  @default(now()) @map("created_at")
  updatedAt    DateTime  @updatedAt @map("updated_at")

  model Model?

  @@map("kycs")
}

model Model {
  id           String     @id @default(uuid())
  firstName    String     @map("first_name")
  lastNameP    String     @map("last_name_p")
  lastNameM    String?    @map("last_name_m")
  artisticName String?    @map("artistic_name")
  email        String     @unique
  phone        String
  birthDate    DateTime   @map("birth_date") @db.Date
  nationality  String?
  genre        ModelGenre

  height            Int?
  weight            Decimal?
  hasVisibleTattoos Boolean? @map("has_visible_tattoos")
  shirtSize         String?  @map("shirt_size")
  pantsSize         String?  @map("pants_size")

  availableToTravel Boolean @default(false) @map("available_to_travel")
  hasPassport       Boolean @default(false) @map("has_passport")
  hasVisaUS         Boolean @default(false) @map("has_visa_us")

  isVisible Boolean @default(false) @map("is_visible")

  kycId String @unique @map("kyc_id")
  kyc   Kyc    @relation(fields: [kycId], references: [id])

  categories Category[]

  countryId String  @map("country_id")
  country   Country @relation(fields: [countryId], references: [id])

  cityId String       @map("city_id")
  city   Municipality @relation(fields: [cityId], references: [id])

  media    ModelMedia[]
  packages Package[]
  eventos  Evento[]

  @@map("models")
}

model Evento {
  id       String   @id @default(uuid())
  nombre   String
  startAt  DateTime @map("start_at")
  endAt    DateTime @map("end_at")
  cubierto Boolean  @default(false)
  notas    String?

  // Recurrence: empty = one-time event; populated = repeats on these JS weekdays (0=Dom,1=Lun…6=Sáb)
  recurringDays  Int[]   @map("recurring_days")
  dailyStartTime String? @map("daily_start_time")
  dailyEndTime   String? @map("daily_end_time")

  modeloId String? @map("modelo_id")
  modelo   Model?  @relation(fields: [modeloId], references: [id])

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("eventos")
}

model Package {
  id          String        @id @default(uuid())
  name        String
  description String?
  publicToken String        @unique @default(uuid()) @map("public_token")
  status      PackageStatus @default(DRAFT)
  createdAt   DateTime      @default(now()) @map("created_at")
  updatedAt   DateTime      @updatedAt @map("updated_at")

  models Model[]

  @@map("packages")
}

model ModelMedia {
  id        String    @id @default(uuid())
  url       String
  type      MediaType
  createdAt DateTime  @default(now()) @map("created_at")

  modelId String @map("model_id")
  model   Model  @relation(fields: [modelId], references: [id], onDelete: Cascade)

  @@map("model_media")
}
