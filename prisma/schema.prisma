// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum UserRole {
  ADMIN
  USER
}

model User {
  id             String   @id @default(uuid())
  email          String   @unique
  username       String
  hashedPassword String   @map("hashed_password")
  role           UserRole @default(USER)
  createdAt      DateTime @default(now()) @map("created_at")

  agencyId String @map("agency_id")
  agency   Agency @relation(fields: [agencyId], references: [id])

  @@map("users")
}

model Agency {
  id        String   @id @default(uuid())
  name      String
  createdAt DateTime @default(now()) @map("created_at")

  users User[]

  @@map("agencies")
}

model Country {
  id      String @id @default(uuid())
  name    String
  label   String  @unique// MX, USA, etc
  demonym String // Mexicano, American, etc

  models Model[]
  states State[]

  @@map("countries")
}

model State {
  id    String @id @default(uuid())
  name  String
  label String @unique // CDMX, SIN, etc

  cities Municipality[]

  countryId String  @map("country_id")
  country   Country @relation(fields: [countryId], references: [id])

  @@map("states")
}

model Municipality {
  id   String @id @default(uuid())
  name String
  label String @unique // CLN,

  stateId String @map("state_id")
  state   State  @relation(fields: [stateId], references: [id])

  models Model[]

  @@map("municipalities")
}

model Category {
  id      String  @id @default(uuid())
  name    String
  enabled Boolean @default(true)

  models Model[]

  @@map("categories")
}

enum ModelGenre {
  MALE
  FEMALE
}

enum KycStatus {
  PENDING
  APPROVED
  REJECTED
  REQUIRES_CHANGES
}

model Kyc {
  id           String    @id @default(uuid())
  status       KycStatus @default(PENDING)
  comment      String?
  internalNote String?   @map("internal_note")
  rejectedAt   DateTime? @map("rejected_at")
  reviewedAt   DateTime? @map("reviewed_at")
  createdAt    DateTime  @default(now()) @map("created_at")
  updatedAt    DateTime  @updatedAt @map("updated_at")

  model Model?

  @@map("kycs")
}

model Model {
  id        String     @id @default(uuid())
  fullName  String     @map("full_name")
  email     String     @unique
  phone     String
  birthDate DateTime   @map("birth_date") @db.Date
  genre     ModelGenre

  kycId String @unique @map("kyc_id")
  kyc   Kyc    @relation(fields: [kycId], references: [id])

  categories Category[]

  countryId String  @map("country_id")
  country   Country @relation(fields: [countryId], references: [id])

  cityId String       @map("city_id")
  city   Municipality @relation(fields: [cityId], references: [id])

  @@map("models")
}
