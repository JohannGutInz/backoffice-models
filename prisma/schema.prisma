generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum UserRole {
  ADMIN
  USER
  MODEL
}

model User {
  id             String   @id @default(uuid())
  email          String   @unique
  username       String
  hashedPassword String   @map("hashed_password")
  role           UserRole @default(USER)
  createdAt      DateTime @default(now()) @map("created_at")

  model Model?

  @@map("users")
}

model Country {
  id      String @id @default(uuid())
  name    String
  label   String @unique // MX, USA, etc
  demonym String // Mexicano, American, etc

  models                Model[] @relation("ModelResidenceCountry")
  modelsWithNationality Model[] @relation("ModelNationality")
  states                State[]

  @@map("countries")
}

model State {
  id    String @id @default(uuid())
  name  String
  label String @unique

  cities Municipality[]

  countryId String  @map("country_id")
  country   Country @relation(fields: [countryId], references: [id])

  @@map("states")
}

model Municipality {
  id    String @id @default(uuid())
  name  String
  label String @unique // CLN,

  stateId String @map("state_id")
  state   State  @relation(fields: [stateId], references: [id])

  models Model[]

  @@map("municipalities")
}

model Category {
  id      String  @id @default(uuid())
  name    String  @unique
  enabled Boolean @default(true)

  models Model[]

  @@map("categories")
}

model Activity {
  id      String  @id @default(uuid())
  name    String
  enabled Boolean @default(true)

  models Model[]

  @@map("activities")
}

enum ModelGenre {
  MALE
  FEMALE
}

enum ShirtSize {
  XS
  S
  M
  L
  XL
  XXL
}

enum PantsSizeScale {
  MEN
  WOMEN
}

enum KycStatus {
  PENDING
  APPROVED
  REJECTED
  REQUIRES_CHANGES
}

enum PackageStatus {
  DRAFT
  SENT
  CLOSED
}

enum MediaType {
  PHOTO_CASUAL
  PHOTO_BOOK
  PHOTO_EVENT
  VIDEO_LINK
}

model Kyc {
  id           String    @id @default(uuid())
  status       KycStatus @default(PENDING)
  comment      String?
  internalNote String?   @map("internal_note")
  rejectedAt   DateTime? @map("rejected_at")
  reviewedAt   DateTime? @map("reviewed_at")
  createdAt    DateTime  @default(now()) @map("created_at")
  updatedAt    DateTime  @updatedAt @map("updated_at")

  model Model?

  @@map("kycs")
}

model Model {
  id               String     @id @default(uuid())
  firstName        String     @map("first_name")
  paternalLastName String     @map("paternal_last_name")
  maternalLastName String?    @map("maternal_last_name")
  email            String     @unique
  phone            String
  birthDate        DateTime   @map("birth_date") @db.Date
  genre            ModelGenre
  createdAt        DateTime   @default(now()) @map("created_at")
  updatedAt        DateTime   @default(now()) @updatedAt @map("updated_at")

  height             Int?            @map("height_cm")
  currentWeight      Int?            @map("current_weight_kg")
  hasVisibleTattoos  Boolean         @default(false) @map("has_visible_tattoos")
  shirtSize          ShirtSize?      @map("shirt_size")
  pantsSizeScale     PantsSizeScale? @map("pants_size_scale")
  pantsSize          String?         @map("pants_size")
  travelAvailability Boolean         @default(false) @map("travel_availability")
  hasPassport        Boolean         @default(false) @map("has_passport")
  hasVisa            Boolean         @default(false) @map("has_visa")

  assets Asset[]

  kycId String @unique @map("kyc_id")
  kyc   Kyc    @relation(fields: [kycId], references: [id])

  userId String @unique @map("user_id")
  user   User   @relation(fields: [userId], references: [id])

  categories Category[]
  activities Activity[]

  countryId String  @map("country_id")
  country   Country @relation("ModelResidenceCountry", fields: [countryId], references: [id])

  nationalityId String  @map("nationality_id")
  nationality   Country @relation("ModelNationality", fields: [nationalityId], references: [id])

  cityId String       @map("city_id")
  city   Municipality @relation(fields: [cityId], references: [id])

  @@map("models")
}

enum AssetType {
  MAIN_PHOTO
  PHOTO
  VIDEO
}

model Asset {
  id        String    @id @default(uuid())
  type      AssetType
  url       String
  position  Int
  createdAt DateTime  @default(now()) @map("created_at")

  modelId String @map("model_id")
  model   Model  @relation(fields: [modelId], references: [id], onDelete: Cascade)

  @@unique([modelId, type, position])
  @@map("assets")
}
